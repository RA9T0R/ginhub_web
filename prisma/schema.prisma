generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

enum Role {
  CUSTOMER
  RESTAURANT
  DELIVERY
}

enum OrderStatus {
  PENDING
  PREPARING
  READY_FOR_PICKUP
  PICKED_UP
  DELIVERED
  CANCELLED
}

enum DiscountType {
  PERCENTAGE
  FIXED
}

model User {
  id       String @id @default(cuid())
  email    String @unique
  password String
  name     String
  role     Role   @default(CUSTOMER)

  customerProfile Customer?
  riderProfile    DeliveryPersonnel?
  restaurants     Restaurant[]

  createdAt DateTime @default(now())
}

model Customer {
  id          String    @id @default(cuid())
  phone       String?
  address     String?
  dateOfBirth DateTime?

  userId String @unique
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  orders              Order[]
  favoriteRestaurants Restaurant[] @relation("CustomerFavorites")
  Coupon              Coupon[]

  createdAt DateTime @default(now())
}

model DeliveryPersonnel {
  id               String    @id @default(cuid())
  phone            String?
  licensePlate     String?
  identificationNo String?
  dateOfBirth      DateTime?

  driverScore    Float   @default(100.0)
  acceptanceRate Float   @default(100.0)
  balance        Float   @default(0.0)
  isOnline       Boolean @default(false)

  userId String @unique
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  orders Order[]

  createdAt DateTime @default(now())
}

model Restaurant {
  id          String  @id @default(cuid())
  name        String
  category    String  @default("ตามสั่ง")
  description String?
  imageUrl    String?
  rating      Float   @default(0.0)
  isOnline    Boolean @default(false)

  ownerId String
  owner   User   @relation(fields: [ownerId], references: [id])

  menus  Menu[]
  orders Order[]

  favoritedBy Customer[] @relation("CustomerFavorites")

  createdAt DateTime @default(now())
}

model Menu {
  id          String  @id @default(cuid())
  name        String
  price       Float
  imageUrl    String?
  isAvailable Boolean @default(true)

  restaurantId   String
  restaurantName String
  restaurant     Restaurant @relation(fields: [restaurantId], references: [id], onDelete: Cascade)

  orderItems OrderItem[]
}

model Order {
  id          String @id @default(cuid())
  totalAmount Float
  deliveryFee Float  @default(15.0)

  discountAmount Float   @default(0.0)
  couponId       String? @unique
  coupon         Coupon? @relation(fields: [couponId], references: [id])

  status      OrderStatus @default(PENDING)
  orderRating Int?

  customerId String
  customer   Customer @relation(fields: [customerId], references: [id])

  restaurantId   String
  restaurantName String
  restaurant     Restaurant @relation(fields: [restaurantId], references: [id])

  riderId String?
  rider   DeliveryPersonnel? @relation(fields: [riderId], references: [id])

  items OrderItem[]

  createdAt DateTime @default(now())
}

model OrderItem {
  id       String  @id @default(cuid())
  quantity Int
  price    Float
  imageUrl String?

  orderId String
  order   Order  @relation(fields: [orderId], references: [id], onDelete: Cascade)

  menuId String
  menu   Menu   @relation(fields: [menuId], references: [id])
}

model Coupon {
  id            String       @id @default(cuid())
  code          String
  description   String
  discountType  DiscountType @default(FIXED)
  discountValue Float
  isUsed        Boolean      @default(false)
  expiresAt     DateTime?

  customerId String
  customer   Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)

  order Order?

  createdAt DateTime @default(now())
}
